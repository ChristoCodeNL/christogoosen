---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Writing — ${SITE_TITLE}`} description="Articles on product management and antifragility." />
  </head>
  <body>
    <Header />
    <main>
      <h1>Writing</h1>
      <ol class="post-list">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`}>
              <span class="post-title">{post.data.title}</span>
              <span class="post-meta">
                <FormattedDate date={post.data.pubDate} />
              </span>
              {post.data.description && (
                <span class="post-description">{post.data.description}</span>
              )}
            </a>
          </li>
        ))}
      </ol>
    </main>
    <Footer />
  </body>
</html>

<style>
  h1 { margin-bottom: 2.5rem; }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-list li { border-bottom: 1px solid var(--border); }

  .post-list li a {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 0.1rem 1rem;
    padding: 1.25rem 0;
    text-decoration: none;
    color: var(--text);
  }

  .post-list li a:hover .post-title { color: var(--accent); }

  .post-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 400;
    grid-column: 1;
    grid-row: 1;
  }

  .post-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
    grid-column: 2;
    grid-row: 1;
    white-space: nowrap;
    align-self: center;
  }

  .post-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    grid-column: 1;
    grid-row: 2;
    line-height: 1.5;
  }

  @media (max-width: 480px) {
    .post-list li a { grid-template-columns: 1fr; }
    .post-meta { grid-column: 1; grid-row: 2; }
    .post-description { grid-row: 3; }
  }
</style>
