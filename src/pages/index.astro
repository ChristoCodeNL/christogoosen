---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const books = (await getCollection('books'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="intro">
        <p class="tagline">On product management, antifragility,<br/>and building things that get stronger under pressure.</p>
      </section>

      <section class="section">
        <div class="section-header">
          <h2>Writing</h2>
          <a href="/blog">All posts &rarr;</a>
        </div>
        <ol class="post-list">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`}>
                <span class="post-title">{post.data.title}</span>
                <span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
              </a>
            </li>
          ))}
        </ol>
      </section>

      {books.length > 0 && (
        <section class="section">
          <div class="section-header">
            <h2>Books</h2>
            <a href="/books">All reviews &rarr;</a>
          </div>
          <ol class="post-list">
            {books.map((book) => (
              <li>
                <a href={`/books/${book.id}/`}>
                  <span class="post-title">{book.data.title}</span>
                  <span class="post-date">{book.data.author}</span>
                </a>
              </li>
            ))}
          </ol>
        </section>
      )}
    </main>
    <Footer />
  </body>
</html>

<style>
  .intro {
    padding: 3rem 0 3.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .tagline {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.6rem;
    font-weight: 300;
    font-style: italic;
    line-height: 1.4;
    color: var(--text);
    margin: 0;
  }

  .section { margin-bottom: 3.5rem; }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.5rem;
  }

  .section-header h2 {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: 'Lora', serif;
    font-weight: 500;
    margin: 0;
    color: var(--text-muted);
  }

  .section-header a {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-decoration: none;
  }

  .section-header a:hover { color: var(--accent); }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-list li { border-bottom: 1px solid var(--border); }

  .post-list li a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.75rem 0;
    text-decoration: none;
    color: var(--text);
    transition: color 0.2s ease;
  }

  .post-list li a:hover .post-title { color: var(--accent); }

  .post-title { font-size: 1rem; }

  .post-date {
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
