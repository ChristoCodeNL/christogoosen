---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---
<header>
  <nav>
    <a href="/" class="site-title">{SITE_TITLE}</a>
    <div class="nav-links">
      <HeaderLink href="/blog">Writing</HeaderLink>
      <HeaderLink href="/books">Books</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <a href="/rss.xml" class="rss-link" aria-label="RSS feed">RSS</a>
    </div>
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border);
    padding: 1.25rem 1rem;
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .site-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.1rem;
    font-weight: 400;
    text-decoration: none;
    color: var(--text);
    letter-spacing: 0.01em;
  }

  .site-title:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 1.75rem;
    align-items: baseline;
  }

  .rss-link {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    font-family: 'Lora', serif;
  }

  .rss-link:hover { color: var(--accent); }

  @media (max-width: 480px) {
    nav { flex-direction: column; gap: 0.75rem; }
    .nav-links { gap: 1.25rem; }
  }
</style>
